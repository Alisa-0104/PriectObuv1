<Window x:Class="ShoeStoreApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="400" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Авторизация" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="LoginTextBox" 
                 Height="30" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Пароль:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" 
                     Height="30" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
            <Button Content="Войти" Height="35" Margin="0,0,0,10"
                    Click="Login_Click" Background="#4CAF50" Foreground="White"/>
            <Button Content="Войти как гость" Height="35"
                    Click="Guest_Click" Background="#2196F3" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>